title: "Acid Mine Drainage Detection System: Advanced Remote Sensing for Environmental Monitoring"
version: 1.5.4
date-released: 2025-01-09
authors:
  - family-names: "Hussein"
    given-names: "Abdulrahman Rabie Ahmed"
